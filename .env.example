# ============================================
# AI CHESS ARCHITECT - Configuration Template
# ============================================
# ⚠️  NE JAMAIS committer de vraies valeurs !
# Copier ce fichier en .env et remplir avec vos vraies clés

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-public-key
VITE_SUPABASE_PROJECT_ID=your-project-id
# Requis seulement pour une URL Supabase sur domaine personnalisé (host exact,
# port inclus s'il n'est pas standard; sans schéma ni chemin)
# VITE_SUPABASE_CUSTOM_HOST=supabase.example.invalid

# Database et scripts serveur uniquement — NE PAS préfixer par VITE_
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_PROJECT_REF_CONFIRMATION=your-project-id

# Écriture distante disponible uniquement via `pnpm sync:tournaments`
SYNC_TOURNAMENTS_CONFIRMED=false

# AI Provider (OpenRouter local gpt-oss)
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter-proxy.example.invalid
OPENROUTER_DEFAULT_MODEL=openai/gpt-oss-20b
# Règle locale (proxy serveur non routable dans cet exemple)
LOCAL_RULE_MODEL_URL=https://local-rule-model.example.invalid
OPENAI_BASE_URL=https://legacy-openai-proxy.example.invalid
OPENAI_DEFAULT_MODEL=openai/gpt-oss-20b
# Optional metadata for OpenRouter requests
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=ai-chess-architect

# Force OpenRouter provider (optional override)
# AI_PROVIDER=openrouter

# Rule Architect V2 — configurer exclusivement comme secrets Supabase Edge
# OPENAI_API_KEY=configure-in-Supabase-Edge-secrets-only
# OPENAI_RULE_MODEL=gpt-5.6-terra
# OPENAI_PREMIUM_RULE_MODEL=gpt-5.6-sol
# ALLOWED_ORIGINS=http://localhost:5173
# RULE_ARCHITECT_PREMIUM_USER_IDS=
# RULE_COMPILE_HOURLY_LIMIT=12
# RULE_COMPILE_STALE_SECONDS=180
# RULE_PROMPT_MAX_CHARS=4000
# Le courtier d'assets sûrs est actif par défaut. Coupe-circuit opérationnel :
# RULE_ASSET_SEARCH_ENABLED=false

# Lovable Deploy Hook (optional)
# LOVABLE_DEPLOY_HOOK=https://api.lovable.dev/deploy/webhook/xxxxx
# LOVABLE_DEPLOY_SECRET=your-deploy-secret

# Development
NODE_ENV=development
VITE_APP_VERSION=1.0.0

# Phase 6: Feature flag pour règles legacy
VITE_ENABLE_LEGACY_RULES=false
